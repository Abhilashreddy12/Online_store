# Environment Variables Example
# Copy this file to .env and fill in your values

# Django Settings
# Generate a new SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-generated-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1


# Local Database Configuration (PostgreSQL)
DB_NAME=clothing_store
DB_USER=postgres
DB_PASSWORD=abhi
DB_HOST=localhost
DB_PORT=5432

# Production (Render) - Set in Render Dashboard
# DATABASE_URL=postgresql://user:password@host/database

# Email settings (do NOT commit real credentials)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Razorpay Payment Gateway
# Get credentials from: https://dashboard.razorpay.com/app/keys
# Use TEST mode credentials for development
RAZORPAY_KEY_ID=rzp_test_SN3DjM3TPsFwCu
RAZORPAY_KEY_SECRET=FTkSG7ejJnqTl67D7uADFkag

# Cloudinary (Optional - for image hosting)
# CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# AI Chatbot (Optional)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email preferences
USE_CONSOLE_EMAIL=True  # Set to True to print emails to console during development
